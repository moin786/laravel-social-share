{
  "name": "peal/laravel-social-share",
  "description": "Auto Open Graph + Multi-platform sharing engine for Laravel",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": "^8.1|^8.2|^8.3|^8.4",
    "illuminate/support": "^10|^11|^12|^13"
  },
  "autoload": {
    "psr-4": {
      "Peal\\SocialShare\\": "src/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Peal\\SocialShare\\LaravelSocialShareServiceProvider"
      ],
      "aliases": {
        "Share": "Peal\\SocialShare\\Facades\\Share"
      }
    }
  }
}
